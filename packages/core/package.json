    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "dependencies": {
    "@agentx/adp": "workspace:*",
    "@ai-sdk/openai": "^1.3.0",
    "ai": "^4.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "vitest": "^1.6.1"
  }
}
