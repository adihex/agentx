    },
    {
      "title": "The Event Loop",
      "description": "AgentEventLoop is the heart. It runs 4 phases per tick: Timers \u2192 I/O Callbacks (tool results) \u2192 Inference (LLM streaming) \u2192 Check (microtasks/guardrails).",
      "order": 4,
      "nodeIds": [
        "class:packages/core/src/AgentEventLoop.ts:AgentEventLoop",
        "function:packages/core/src/AgentEventLoop.ts:tick"
      ]
    },
    {
      "title": "Non-Blocking Tools",
      "description": "AgenticThreadPool runs tools in worker_threads. dispatchTool is fire-and-forget; results arrive asynchronously and are drained in Phase 2.",
      "order": 5,
      "nodeIds": [
        "class:packages/core/src/AgenticThreadPool.ts:AgenticThreadPool",
        "function:packages/core/src/AgentEventLoop.ts:dispatchTool",
