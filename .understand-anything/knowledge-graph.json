  "tour": [
    {
      "title": "Welcome to agentx",
      "description": "agentx is an event-driven AI agent runtime modeled on Node.js and Chrome DevTools Protocol. It has 10 source files across a monorepo with 3 packages.",
      "order": 1,
      "nodeIds": ["file:apps/demo/src/index.ts"]
    },
    {
      "title": "The ADP Control Plane",
      "description": "Start with the Agent Debugger Protocol (ADP). This is the out-of-band WebSocket control plane that lets you halt inference, pause the agent, or compact memory from a separate CLI.",
      "order": 2,
      "nodeIds": [
        "file:packages/adp/src/schemas.ts",
        "class:packages/adp/src/server.ts:AdpServer",
