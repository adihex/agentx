    {
      "title": "Schemas & Types",
      "description": "All JSON-RPC 2.0 messages are validated with Zod. AdpDomains defines the command namespaces: Inference, Metacognition, Toolchain, and Memory.",
      "order": 3,
      "nodeIds": [
        "concept:packages/adp/src/schemas.ts:AdpDomains",
