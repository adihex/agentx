{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "rootDir": "."
  },
  "include": [
    "app/**/*",
    "app.config.ts",
    "vitest.config.ts",
    "vitest-setup.ts",
    "playwright.config.ts",
    "e2e/**/*"
  ]
}
